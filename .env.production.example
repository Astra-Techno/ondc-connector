# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
APP_NAME=ONDC-Connector

# ─── MySQL (VPS) ──────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ondc_connector
DB_USER=ondc_user
DB_PASSWORD=YOUR_STRONG_DB_PASSWORD

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=YOUR_STRONG_JWT_SECRET_HERE

# ─── CottKart API ─────────────────────────────────────────────────────────────
CLOUDKART_API_URL=https://cottkart.com
CLOUDKART_API_KEY=YOUR_COTTKART_API_KEY

# ─── ONDC ─────────────────────────────────────────────────────────────────────
ONDC_SUBSCRIBER_ID=ondc.cottkart.com
ONDC_SUBSCRIBER_URL=https://ondc.cottkart.com
ONDC_UNIQUE_KEY_ID=ee5e013a-0914-4cbf-bd1c-6dfe9d6709c0
ONDC_SIGNING_PUBLIC_KEY=LYIZkHZ+CmiOoGb9m2d4l27T7d70u+sONDddlZ1+Guk=
ONDC_SIGNING_PRIVATE_KEY=dq2/ZhdhsgN3QE8x7LDD8Zehd1eIAKmMExWcpOEh9mUtghmQdn4KaI6gZv2bZ3iXbtPt3vS76w40N12VnX4a6Q==
ONDC_ENCRYPTION_PUBLIC_KEY=MCowBQYDK2VuAyEASh6YtwrGAwNiq/kK5bb1NA36EcTfuGdN3xgDTLnEeTI=
ONDC_ENCRYPTION_PRIVATE_KEY=MC4CAQAwBQYDK2VuBCIEIHB9M6kl4GcmzbpugKBohLEjZdEzt91LQsL7FN41aBt+
ONDC_ENV=preprod
ONDC_REGISTRY_URL=https://preprod.registry.ondc.org/ondc
ONDC_GATEWAY_URL=https://preprod.gateway.ondc.org
ONDC_DOMAIN=ONDC:RET10
ONDC_CITY_CODE=*
ONDC_COUNTRY_CODE=IND

# ─── Support contacts (used in /support ONDC callback) ────────────────────────
SUPPORT_PHONE=+919999999999
SUPPORT_EMAIL=support@cottkart.com

# ─── Settlement ───────────────────────────────────────────────────────────────
PLATFORM_COMMISSION=2
CASHFREE_API_URL=https://payout-gamma.cashfree.com
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PATH=./logs

# ─── ONDC Network Observability (required for Pramaan sync response checks) ───
# Request bearer token from tech@ondc.org — without this, Pramaan Flow 1A fails
# on select/init/confirm sync response verification.
# Preprod analytics (required for Pramaan sync-response checks):
ONDC_ANALYTICS_URL=https://analytics-api-pre-prod.aws.ondc.org/v1/api/push-txn-logs
# Max ms to wait for N.O. push before returning sync ACK (default 2500)
# ONDC_SYNC_LOG_DEADLINE_MS=2500
ONDC_ANALYTICS_TOKEN=

# ─── Default tenant ───────────────────────────────────────────────────────────
DEFAULT_TENANT_SLUG=cottkart
